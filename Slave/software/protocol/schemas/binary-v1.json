        "endsWithHex": "ffd9"
      }
    },
    {
      "id": 16,
      "hex": "0x10",
      "name": "speaker_pcm",
      "direction": "brain-to-body",
      "payload": {
        "exactBytes": 640,
        "encoding": "pcm_s16le",
        "sampleRateHz": 16000,
        "channels": 1,
        "durationMs": 20
      }
    }
  ]
}
