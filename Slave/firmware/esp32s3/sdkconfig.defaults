CONFIG_AINEKIO_PIN_MAP_B=y
CONFIG_AINEKIO_PHYSICAL_MOTION_ENABLED=y
CONFIG_AINEKIO_MOTION_RANGE_PERCENT=25
CONFIG_AINEKIO_MOTION_MIN_FRAME_MS=100
CONFIG_AINEKIO_SERVO_STARTUP_STAGGER_MS=20
