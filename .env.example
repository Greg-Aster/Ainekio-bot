# Ainekio environment adapter
# Configure the same value as MH_ENVIRONMENT_ADAPTER_TOKEN in MetaHuman OS.
AINEKIO_ENVIRONMENT_ADAPTER_TOKEN=replace-with-a-long-random-token
AINEKIO_ENVIRONMENT_SESSION_ID=ainekio-01

# Local robot discovery (default connection path)
AINEKIO_LOCAL_DISCOVERY=1

# Optional remote robot relay. Keep the credential JSON outside the repo.
AINEKIO_CLOUDFLARE_TUNNEL_ID=replace-with-ainekio-robot-tunnel-uuid
AINEKIO_CLOUDFLARE_CREDENTIALS_FILE=/absolute/path/outside/repo/tunnel-credentials.json
